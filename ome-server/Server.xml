<?xml version="1.0" encoding="UTF-8"?>
<Server version="8">
    <Name>OvenMediaEngine</Name>
    <Type>origin</Type>
    <IP>*</IP>

    <Modules>
		<LLHLS>
			<Enable>true</Enable>
		</LLHLS>
	</Modules>

    <Bind>
        <Providers>
            <RTMP>
                <Port>1935</Port>
            </RTMP>
        </Providers>
        <Publishers>
            <LLHLS>
                <!-- Plain HTTP: only reachable inside the docker network -->
                <Port>8888</Port>
            </LLHLS>
        </Publishers>
    </Bind>

    <VirtualHosts>
        <VirtualHost>
            <Name>default</Name>
            <Host>
				<Names>
					<Name>*</Name>
				</Names>
				<TLS>
					<CertPath>/opt/ovenmediaengine/bin/ssl-config/cert.pem</CertPath>
					<KeyPath>/opt/ovenmediaengine/bin/ssl-config/key.pem</KeyPath>
				</TLS>
			</Host>

            <Applications>                
                <Application>
                    <Name>live</Name>
                    <Type>live</Type>
                    <OutputProfiles>
                        <OutputProfile>
                            <Name>bypass</Name>
                            <OutputStreamName>${OriginStreamName}</OutputStreamName>
                            <!-- ABR: viewers on a degraded network (e.g. crowded
                                 venue WiFi) auto-switch to the 360p rendition;
                                 playback URL is /<app>/<stream>/abr.m3u8 -->
                            <Playlist>
                                <Name>llhls_abr</Name>
                                <FileName>abr</FileName>
                                <Rendition>
                                    <Name>source</Name>
                                    <Video>bypass_video</Video>
                                    <Audio>bypass_audio</Audio>
                                </Rendition>
                                <Rendition>
                                    <Name>low</Name>
                                    <Video>video_480p</Video>
                                    <Audio>bypass_audio</Audio>
                                </Rendition>
                            </Playlist>
                            <Encodes>
                                <Video>
                                    <Name>bypass_video</Name>
                                    <Bypass>true</Bypass>
                                </Video>
                                <Audio>
                                    <Name>bypass_audio</Name>
                                    <Bypass>true</Bypass>
                                </Audio>
                                <Video>
                                    <Name>video_480p</Name>
                                    <Codec>h264</Codec>
                                    <Bitrate>800000</Bitrate>
                                    <Width>854</Width>
                                    <Height>480</Height>
                                    <!-- 60 frames = 2s GOP at 30fps, aligned with
                                         SegmentDuration for clean ABR switching -->
                                    <KeyFrameInterval>60</KeyFrameInterval>
                                    <BFrames>0</BFrames>
                                    <Preset>faster</Preset>
                                </Video>
                            </Encodes>
                        </OutputProfile>
                    </OutputProfiles>
                    <Providers>
                        <RTMP />
                    </Providers>
                    <Publishers>
                        <LLHLS>
                            <ChunkDuration>0.2</ChunkDuration>
                            <SegmentDuration>2</SegmentDuration>
                            <SegmentCount>3</SegmentCount>
                            <CrossDomains>
                                <Url>*</Url>
                            </CrossDomains>
                        </LLHLS>
                    </Publishers>
                </Application>
            </Applications>
        </VirtualHost>
    </VirtualHosts>
</Server>